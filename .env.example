MAGERLIFE_API_PORT=8787
MAGERLIFE_API_HOST=127.0.0.1

# Public backend URL for local frontend calls. This is not a secret.
VITE_MAGERLIFE_API_BASE_URL=http://127.0.0.1:8787

# LLM provider. Supported now: groq, xai, mock.
MAGERLIFE_LLM_PROVIDER=groq

# Groq. Keep this only in .env, never in frontend code.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# xAI/Grok fallback if you switch provider later.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=latest

# Optional switches.
MAGERLIFE_ENABLE_REAL_LLM=true

# Session signing. Set a long random value before deploying.
MAGERLIFE_SESSION_SECRET=change-this-before-production

# Comma-separated emails that the server may bootstrap as admin/pro.
# Example: MAGERLIFE_ADMIN_EMAILS=admin@magerlife.local,you@example.com
MAGERLIFE_ADMIN_EMAILS=

# Simple per-IP route rate limit for the Node API.
MAGERLIFE_RATE_LIMIT_PER_MIN=180

# Server-to-server secret for payment provider webhooks.
MAGERLIFE_BILLING_WEBHOOK_SECRET=change-this-before-payment-webhooks
MAGERLIFE_PRO_PRICE_VND=149000

# PayOS payment provider.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=

# MoMo payment provider.
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_IPN_URL=
MOMO_REDIRECT_URL=
MOMO_REQUEST_TYPE=payWithMethod

# VNPay payment provider.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=

# Persistence. Keep memory for local demo, postgres for real DB.
MAGERLIFE_DB_DRIVER=memory
DATABASE_URL=
DATABASE_SSL=false
